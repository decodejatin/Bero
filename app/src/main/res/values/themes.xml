<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme — Luxury Royal -->
    <style name="Theme.Bero" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color — Deep Charcoal -->
        <item name="colorPrimary">#FF1A1A2E</item>
        <item name="colorPrimaryVariant">#FF12121F</item>
        <item name="colorOnPrimary">#FFF5F0E8</item>
        <!-- Secondary brand color — Champagne Gold -->
        <item name="colorSecondary">#FFC9A84C</item>
        <item name="colorSecondaryVariant">#FFAD8F3A</item>
        <item name="colorOnSecondary">#FF1A1A2E</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Splash theme: onyx background, no action bar, prevents white flash -->
    <style name="Theme.Bero.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:navigationBarColor">@color/splash_background</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>